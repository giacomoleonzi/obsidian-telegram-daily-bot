# Copy to config/.env and set your real values.
TELEGRAM_BOT_TOKEN=replace_with_your_bot_token
AUTHORIZED_CHAT_ID=123456789

# Required variables used by setup.sh and bot.py
OB_VAULT_PATH=/vault
OB_DEVICE_NAME=raspberrypi
OB_EMAIL=
OB_PASSWORD=
# Do not persist MFA in file. Export OB_MFA only for one-time use if needed.
BOT_DAILY_SUBDIR=Daily-folder
BOT_MEDIA_SUBDIR=Media-folder
BOT_DAILY_NOTE_FORMAT=%Y-%m-%d
BOT_LOG_LEVEL=INFO
BOT_NOTE_TEMPLATE=![[{audio_file}]]
BOT_IMAGE_NOTE_TEMPLATE=![[{image_file}]]
IMAGE_COMPRESSION_ENABLED=true
IMAGE_MAX_BYTES=5242880
IMAGE_MAX_DIMENSION=2560
IMAGE_JPEG_QUALITY_START=90
IMAGE_JPEG_QUALITY_MIN=55
IMAGE_JPEG_QUALITY_STEP=5

# Speech-to-text (local whisper.cpp)
STT_PROVIDER=local
STT_LANGUAGE=it
WHISPER_CLI_PATH=/usr/local/bin/whisper-cli
WHISPER_MODEL_PATH=/models/ggml-base.bin

# Summary (for SUMMARY_PROVIDER=gemini, set GEMINI_API_KEY)
SUMMARY_PROVIDER=local
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_SUMMARY_PROMPT=Summarize the text in Italian in at most 5 practical bullet points. Keep a neutral tone and do not invent details.
